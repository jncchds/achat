# PostgreSQL
POSTGRES_DB=achat
POSTGRES_USER=achat
POSTGRES_PASSWORD=achat

# JWT — use a long random string (min 32 chars)
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ISSUER=AChat
JWT_AUDIENCE=AChat
JWT_EXPIRES_IN_MINUTES=1440

# AES-256 encryption key — generate with:
# [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Max 256) }))
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE_AES_KEY=

# Telegram — public HTTPS URL where your API is reachable (used to register per-bot webhooks)
TELEGRAM_WEBHOOK_BASE_URL=https://your-domain-here

# Admin account (created on first startup)
ADMIN_EMAIL=admin@achat.local
ADMIN_PASSWORD=CHANGE_ME
# Optional: when true, force-update the first non-stub user on each startup
# (sets email/password from ADMIN_EMAIL/ADMIN_PASSWORD and grants admin)
ADMIN_FORCE_UPDATE_FIRST_USER=false

# Self-evolution thresholds (optional — defaults shown)
SUMMARIZATION_THRESHOLD=50
SUMMARIZATION_BATCH_SIZE=30
PERSONA_EVOLUTION_MESSAGE_INTERVAL=20
RECENT_MESSAGE_WINDOW_SIZE=20
RAG_TOP_K=5
